def cmd_niri_action(args: argparse.Namespace) -> None:
    action_argv: list[str]
    default_risk = "low"
    if args.action == "focus-window":
        if args.id is None:
            raise AIUIError("focus-window requires --id", code=25)
        action_argv = ["focus-window", "--id", str(args.id)]
    elif args.action == "focus-workspace":
        if args.index is None:
            raise AIUIError("focus-workspace requires --index", code=25)
        action_argv = ["focus-workspace", str(args.index)]
    elif args.action == "toggle-overview":
        action_argv = ["toggle-overview"]
    elif args.action == "close-window":
        action_argv = ["close-window"]
        default_risk = "high"
    else:
        raise AIUIError(f"unsupported niri action: {args.action}", code=25)

    detail = "niri msg action " + " ".join(shlex.quote(item) for item in action_argv)
    risk, _ = prepare_action(
        kind=f"niri-action:{args.action}",
        requested_risk=args.risk or default_risk,
        reason=args.reason or f"perform Niri action {args.action}",
        detail=detail,
        allow_sensitive=args.action in {"focus-window", "focus-workspace", "toggle-overview"},
    )
    try:
        cp = run_external(["niri", "msg", "action", *action_argv], timeout=20)
        if cp.returncode != 0:
            raise AIUIError("niri action failed", code=25, details={"stderr": cp.stderr.strip(), "stdout": cp.stdout.strip()})
        log_event("niri_action", action=args.action, argv=action_argv, risk=risk, reason=args.reason)
        emit({"ok": True, "action": args.action, "risk": risk, "stdout": cp.stdout.strip()})
    finally:
        restore_ready_after_action()


def cmd_run(args: argparse.Namespace) -> None:
    argv = list(args.argv)
    if argv and argv[0] == "--":
        argv = argv[1:]
    if not argv:
        raise AIUIError("run requires a command after `--`", code=26)
    policy = load_policy()
    classified, why = classify_command(argv, policy, cwd=args.cwd)
    requested = args.risk or classified
    risk = risk_max(requested, classified)
    detail = f"run structured command: {shlex.join(argv)}\nClassifier: {why}\nWorking directory: {args.cwd or os.getcwd()}"
    risk, _ = prepare_action(
        kind="run",
        requested_risk=risk,
        reason=args.reason or "run a command-line tool for the current desktop task",
        detail=detail,
        allow_sensitive=False,
    )
    try:
        cp = run_external(argv, timeout=args.timeout, cwd=args.cwd)
        stdout = cp.stdout[-16000:]
        stderr = cp.stderr[-16000:]
        log_event(
            "run",
            argv=argv,
            cwd=args.cwd or os.getcwd(),
            risk=risk,
            reason=args.reason,
            classifier=why,
            returncode=cp.returncode,
        )
        emit(
            {
                "ok": cp.returncode == 0,
                "returncode": cp.returncode,
                "risk": risk,
                "classifier": why,
                "stdout": stdout,
                "stderr": stderr,
            },
            code=0 if cp.returncode == 0 else cp.returncode,
        )
    finally:
        restore_ready_after_action()


