def resolve_x11_window(args: argparse.Namespace) -> str:
    if args.window_id:
        return str(args.window_id)
    cp = run_external(["xdotool", "search", "--name", args.window_name], timeout=10)
    if cp.returncode != 0:
        raise AIUIError(
            "xdotool could not find a matching X11 window",
            code=28,
            details={"stderr": cp.stderr.strip(), "window_name": args.window_name},
        )
    for line in cp.stdout.splitlines():
        value = line.strip()
        if value:
            return value
    raise AIUIError("xdotool search returned no window ids", code=28, details={"window_name": args.window_name})


