#!/usr/bin/env python3
"""Niri/Wayland computer-use control surface.

This is deliberately a local policy wrapper, not a privilege boundary. Every UI
operation updates a Waybar-readable state file, is audited, and honors pause and
emergency-stop flags. High-risk operations require an exact, blocking user
approval immediately before execution.
"""

from __future__ import annotations

import argparse
import contextlib
import datetime as dt
import fcntl
import glob
import hashlib
import json
import os
import re
import secrets
import shlex
import shutil
import signal
import stat
import subprocess
import sys
import tempfile
import time
from pathlib import Path
from typing import Any, Callable, Iterable, Sequence

VERSION = "2.3.0"
SCRIPT_PATH = Path(__file__).resolve()
POLICY_PATH = SCRIPT_PATH.with_name("policy.json")
RISK_ORDER = {"low": 0, "medium": 1, "high": 2, "deny": 3}
VALID_MODES = {
    "idle",
    "ready",
    "observing",
    "acting",
    "approval",
    "paused",
    "stopped",
    "error",
}


class AIUIError(RuntimeError):
    def __init__(self, message: str, *, code: int = 1, details: dict[str, Any] | None = None):
        super().__init__(message)
        self.code = code
        self.details = details or {}


def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat(timespec="seconds")


def load_policy() -> dict[str, Any]:
    try:
        data = json.loads(POLICY_PATH.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise AIUIError(f"failed to load policy: {exc}", code=2) from exc
    if data.get("version") != 2:
        raise AIUIError("unsupported policy version", code=2, details={"path": str(POLICY_PATH)})
    return data


def xdg_runtime_dir() -> Path:
    raw = os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"
    base = Path(raw)
    if not base.is_dir():
        base = Path(tempfile.gettempdir()) / f"aiui-{os.getuid()}"
    target = base / "aiui"
    target.mkdir(mode=0o700, parents=True, exist_ok=True)
    with contextlib.suppress(OSError):
        target.chmod(0o700)
    return target


def xdg_state_dir() -> Path:
    base = Path(os.environ.get("XDG_STATE_HOME") or Path.home() / ".local/state")
    target = base / "aiui"
    target.mkdir(mode=0o700, parents=True, exist_ok=True)
    with contextlib.suppress(OSError):
        target.chmod(0o700)
    return target


def state_path() -> Path:
    return xdg_runtime_dir() / "state.json"


def state_lock_path() -> Path:
    return xdg_runtime_dir() / "state.lock"


def audit_path() -> Path:
    return xdg_state_dir() / "audit.jsonl"


def default_state() -> dict[str, Any]:
    return {
        "version": 2,
        "mode": "idle",
        "session_id": None,
        "task": "",
        "last_action": "",
        "last_error": "",
        "risk": "low",
        "pending": None,
        "source": "",
        "updated_at": now_iso(),
    }


def _read_state_unlocked() -> dict[str, Any]:
    path = state_path()
    if not path.exists():
        return default_state()
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return default_state() | {"mode": "error", "last_error": "state file was unreadable"}
    if not isinstance(value, dict) or value.get("mode") not in VALID_MODES:
        return default_state() | {"mode": "error", "last_error": "state file had an invalid schema"}
    return default_state() | value


def _atomic_json_write(path: Path, value: dict[str, Any], mode: int = 0o600) -> None:
    path.parent.mkdir(mode=0o700, parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.{os.getpid()}.{secrets.token_hex(4)}.tmp")
    fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_EXCL, mode)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(value, handle, ensure_ascii=False, separators=(",", ":"))
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(tmp, path)
        with contextlib.suppress(OSError):
            path.chmod(mode)
    finally:
        with contextlib.suppress(FileNotFoundError):
            tmp.unlink()


def read_state() -> dict[str, Any]:
    lock = state_lock_path()
    with lock.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_SH)
        return _read_state_unlocked()


def update_state(*, signal_waybar: bool = True, **changes: Any) -> dict[str, Any]:
    lock = state_lock_path()
    with lock.open("a+", encoding="utf-8") as handle:
        fcntl.flock(handle.fileno(), fcntl.LOCK_EX)
        current = _read_state_unlocked()
        current.update(changes)
        current["updated_at"] = now_iso()
        _atomic_json_write(state_path(), current)
    if signal_waybar:
        refresh_waybar()
    return current


def refresh_waybar() -> None:
    try:
        signum = int(load_policy().get("waybar_signal", 10))
    except (AIUIError, TypeError, ValueError):
        signum = 10
    if signum < 1 or signum > 31:
        signum = 10
    pkill = shutil.which("pkill")
    if pkill:
        subprocess.run(
            [pkill, f"-RTMIN+{signum}", "waybar"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )


def redact_text(value: str, limit: int = 500) -> str:
    result = value
    patterns = [
        r"(?i)(password|passphrase|token|secret|api[_-]?key)(\s*[:=]\s*)(\S+)",
        r"(?i)(authorization:\s*bearer\s+)(\S+)",
    ]
    for pattern in patterns:
        result = re.sub(pattern, r"\1\2<redacted>", result)
    if len(result) > limit:
        result = result[:limit] + "…"
    return result


def log_event(kind: str, **fields: Any) -> None:
    event = {"ts": now_iso(), "kind": kind, "pid": os.getpid()}
    for key, value in fields.items():
        if isinstance(value, str):
            event[key] = redact_text(value)
        elif isinstance(value, list):
            event[key] = [redact_text(str(item)) for item in value]
        else:
            event[key] = value
    path = audit_path()
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)
    with os.fdopen(fd, "a", encoding="utf-8") as handle:
        handle.write(json.dumps(event, ensure_ascii=False, separators=(",", ":")) + "\n")


def emit(value: dict[str, Any], *, code: int = 0, compact: bool = False) -> None:
    if compact:
        print(json.dumps(value, ensure_ascii=False, separators=(",", ":")))
    else:
        print(json.dumps(value, ensure_ascii=False, indent=2))
    raise SystemExit(code)


def is_socket(path: str | Path) -> bool:
    try:
        return stat.S_ISSOCK(os.stat(path).st_mode)
    except OSError:
        return False


def discover_session_env(env: dict[str, str] | None = None) -> dict[str, str]:
    target = env if env is not None else os.environ
    runtime = target.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"
    target.setdefault("XDG_RUNTIME_DIR", runtime)

    if not target.get("WAYLAND_DISPLAY"):
        for candidate in sorted(glob.glob(f"{runtime}/wayland-*")):
            if is_socket(candidate):
                target["WAYLAND_DISPLAY"] = Path(candidate).name
                break

    if not target.get("NIRI_SOCKET"):
        candidates: list[str] = []
        for pattern in (
            f"{runtime}/niri*.sock",
            f"{runtime}/niri*socket*",
            f"{runtime}/niri*/socket",
        ):
            candidates.extend(glob.glob(pattern))
        for candidate in sorted(set(candidates)):
            if is_socket(candidate):
                target["NIRI_SOCKET"] = candidate
                break

    if not target.get("DBUS_SESSION_BUS_ADDRESS") and is_socket(f"{runtime}/bus"):
        target["DBUS_SESSION_BUS_ADDRESS"] = f"unix:path={runtime}/bus"

    if not target.get("YDOTOOL_SOCKET") and is_socket("/run/ydotoold/socket"):
        target["YDOTOOL_SOCKET"] = "/run/ydotoold/socket"

    return target


def run_external(
    argv: Sequence[str],
    *,
    input_text: str | None = None,
    timeout: float = 30,
    capture: bool = True,
    check: bool = False,
    cwd: str | None = None,
) -> subprocess.CompletedProcess[str]:
    env = discover_session_env(os.environ.copy())
    kwargs: dict[str, Any] = {
        "args": list(argv),
        "text": True,
        "input": input_text,
        "timeout": timeout,
        "check": check,
        "env": env,
        "cwd": cwd,
    }
    if capture:
        kwargs["stdout"] = subprocess.PIPE
        kwargs["stderr"] = subprocess.PIPE
    else:
        kwargs["stdout"] = subprocess.DEVNULL
        kwargs["stderr"] = subprocess.DEVNULL
    return subprocess.run(**kwargs)


def notify(summary: str, body: str = "", *, urgency: str = "normal") -> None:
    if not shutil.which("notify-send"):
        return
    try:
        env = discover_session_env(os.environ.copy())
        subprocess.Popen(
            [
                "notify-send",
                "--app-name",
                "AIUI",
                "--urgency",
                urgency,
                summary,
                body,
            ],
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except OSError:
        pass


def niri_json(*args: str, timeout: float = 10) -> Any:
    if not shutil.which("niri"):
        raise AIUIError("niri is not in PATH", code=20)
    cp = run_external(["niri", "msg", "--json", *args], timeout=timeout)
    if cp.returncode != 0:
        raise AIUIError(
            cp.stderr.strip() or cp.stdout.strip() or "niri IPC failed",
            code=20,
            details={"argv": ["niri", "msg", "--json", *args]},
        )
    try:
        return json.loads(cp.stdout)
    except json.JSONDecodeError as exc:
        raise AIUIError("niri returned invalid JSON", code=20, details={"stdout": cp.stdout[-1000:]}) from exc


def unwrap_niri(value: Any) -> Any:
    if isinstance(value, dict) and "Ok" in value:
        ok = value["Ok"]
        if isinstance(ok, dict) and len(ok) == 1:
            return next(iter(ok.values()))
        return ok
    return value


def focused_window() -> dict[str, Any] | None:
    try:
        value = unwrap_niri(niri_json("focused-window"))
    except AIUIError:
        return None
    if value is None:
        return None
    if isinstance(value, dict):
        if "FocusedWindow" in value and isinstance(value["FocusedWindow"], dict):
            return value["FocusedWindow"]
        return value
    return None


def regex_matches(patterns: Iterable[str], text: str) -> str | None:
    for pattern in patterns:
        try:
            if re.search(pattern, text):
                return pattern
        except re.error:
            continue
    return None


def sensitive_window_reason(window: dict[str, Any] | None, policy: dict[str, Any]) -> str | None:
    if not window:
        return None
    app_id = str(window.get("app_id") or "")
    title = str(window.get("title") or "")
    match = regex_matches(policy.get("sensitive_app_patterns", []), app_id)
    if match:
        return f"focused app_id matches sensitive policy: {app_id}"
    match = regex_matches(policy.get("sensitive_title_patterns", []), title)
    if match:
        return f"focused title matches sensitive policy: {redact_text(title, 120)}"
    return None


def focused_is_terminal(window: dict[str, Any] | None, policy: dict[str, Any]) -> bool:
    if not window:
        return False
    app_id = str(window.get("app_id") or "")
    return regex_matches(policy.get("terminal_app_patterns", []), app_id) is not None


def risk_max(*risks: str) -> str:
    return max(risks, key=lambda value: RISK_ORDER.get(value, -1))


def infer_content_risk(reason: str, detail: str, policy: dict[str, Any]) -> tuple[str, str]:
    combined = f"{reason}\n{detail}"
    deny = regex_matches(policy.get("deny_content_patterns", []), combined)
    if deny:
        return "deny", f"matches protected-content pattern: {deny}"
    high = regex_matches(policy.get("high_risk_action_patterns", []), combined)
    if high:
        return "high", f"matches high-risk action pattern: {high}"
    return "low", "no keyword escalation"


def expanded_blocked_paths(policy: dict[str, Any]) -> list[Path]:
    values: list[Path] = []
    for raw in policy.get("blocked_paths", []):
        values.append(Path(os.path.expandvars(os.path.expanduser(str(raw)))).resolve(strict=False))
    return values


def argv_mentions_blocked_path(
    argv: Sequence[str], policy: dict[str, Any], *, cwd: str | None = None
) -> str | None:
    blocked = expanded_blocked_paths(policy)
    base = Path(cwd or os.getcwd()).expanduser().resolve(strict=False)
    for item in argv:
        if not item or item.startswith("-"):
            continue
        candidate = Path(os.path.expandvars(os.path.expanduser(item)))
        if not candidate.is_absolute():
            candidate = base / candidate
        resolved = candidate.resolve(strict=False)
        for root in blocked:
            try:
                resolved.relative_to(root)
                return str(root)
            except ValueError:
                continue
    return None


def classify_command(
    argv: Sequence[str], policy: dict[str, Any], *, cwd: str | None = None
) -> tuple[str, str]:
    if not argv:
        return "deny", "empty command"
    command = Path(argv[0]).name
    lower = [item.lower() for item in argv]

    blocked = argv_mentions_blocked_path(argv, policy, cwd=cwd)
    if blocked:
        return "deny", f"mentions protected path: {blocked}"

    if command in set(policy.get("deny_commands", [])):
        return "deny", f"command is denied: {command}"

    if command in {"bash", "sh", "zsh", "fish", "dash"} and any(flag in lower[1:] for flag in ("-c", "--command")):
        return "deny", "shell command strings are not allowed through the structured runner"

    if command == "git":
        sub = lower[1] if len(lower) > 1 else ""
        if sub in {"status", "diff", "log", "show", "rev-parse"}:
            return "low", f"read-only git subcommand: {sub}"
        if sub in {"push", "clean", "reset", "commit", "merge", "rebase", "checkout", "switch", "restore", "add"}:
            return "high", f"state-changing git subcommand: {sub}"
        return "high", "unclassified git subcommand"

    if command == "niri":
        if len(lower) >= 3 and lower[1] == "msg" and lower[2] in {"--json", "-j"}:
            return "low", "read-only niri JSON query"
        return "high", "direct niri action; use the dedicated niri-action command"

    if command == "nix":
        joined = " ".join(lower[1:])
        if any(token in joined for token in ("flake update", "profile remove", "store delete", "collect-garbage")):
            return "high", "state-changing nix operation"
        if lower[1:2] in (["eval"], ["path-info"], ["show-derivation"], ["flake"]):
            return "medium", "nix command may evaluate or fetch inputs"
        return "high", "unclassified nix operation"

    if command == "sed" and any(item == "-i" or item.startswith("-i") for item in argv[1:]):
        return "high", "sed in-place edit"
    if command == "find" and any(item in {"-delete", "-exec", "-execdir", "-ok", "-okdir"} for item in lower[1:]):
        return "high", "state-changing find expression"

    if command in set(policy.get("readonly_commands", [])):
        return "low", f"read-only command allowlist: {command}"
    if command in set(policy.get("high_risk_commands", [])):
        return "high", f"command requires approval: {command}"
    return "high", "command is not classified as read-only"


def classify_launch_command(
    argv: Sequence[str], policy: dict[str, Any], *, cwd: str | None = None
) -> tuple[str, str]:
    classified, why = classify_command(argv, policy, cwd=cwd)
    if classified in {"deny", "low", "medium"}:
        return classified, why
    command = Path(argv[0]).name if argv else ""
    if command in set(policy.get("gui_launch_commands", [])):
        if len(argv) == 1:
            return "medium", f"GUI launch allowlist: {command}"
        return "high", f"GUI launch allowlist command with arguments: {command}"
    return classified, why


def operational_state(*, require_session: bool = True) -> dict[str, Any]:
    state = read_state()
    mode = state.get("mode")
    if mode == "stopped":
        raise AIUIError(
            "AI desktop control is emergency-stopped; only the user may reset it from the Waybar/launcher menu",
            code=40,
        )
    if mode == "paused":
        raise AIUIError("AI desktop control is paused", code=41)
    if mode == "approval":
        raise AIUIError("another action is waiting for approval", code=42)
    if require_session and not state.get("session_id"):
        raise AIUIError("no active AIUI session; run `aiui session start --task ...` first", code=43)
    return state


def restore_ready_after_action() -> None:
    state = read_state()
    if state.get("mode") in {"stopped", "paused"}:
        return
    update_state(mode="ready" if state.get("session_id") else "idle", pending=None)


def action_fingerprint(kind: str, detail: str) -> str:
    return hashlib.sha256(f"{kind}\0{detail}".encode("utf-8")).hexdigest()[:12]


def fuzzel_select(options: Sequence[str], *, prompt: str, width: int = 72, timeout: float = 600) -> str:
    if not shutil.which("fuzzel") or not os.environ.get("WAYLAND_DISPLAY"):
        return ""
    cp = run_external(
        [
            "fuzzel",
            "--dmenu",
            "--prompt",
            prompt,
            "--cache",
            "/dev/null",
            "--width",
            str(width),
            "--lines",
            str(max(3, len(options))),
        ],
        input_text="\n".join(options) + "\n",
        timeout=timeout,
    )
    if cp.returncode != 0:
        return ""
    return cp.stdout.strip()


def terminal_confirmation(prompt: str) -> str:
    if not sys.stdin.isatty():
        return ""
    print(prompt, file=sys.stderr)
    print("Type APPROVE to approve once, PAUSE to pause, or anything else to deny:", file=sys.stderr)
    return sys.stdin.readline().strip().upper()


def request_approval(*, kind: str, risk: str, reason: str, detail: str) -> None:
    policy = load_policy()
    mode = str(policy.get("approval_mode", "balanced"))
    require = risk == "high" or (risk == "medium" and mode == "strict")
    if risk == "deny":
        log_event("blocked", action=kind, risk=risk, reason=reason, detail=detail)
        if policy.get("notifications", {}).get("blocked", True):
            notify("AI action blocked", redact_text(reason, 160), urgency="critical")
        raise AIUIError("policy denied this action", code=50, details={"reason": reason, "detail": detail})
    if not require:
        return

    state = operational_state(require_session=True)
    fingerprint = action_fingerprint(kind, detail)
    pending = {
        "fingerprint": fingerprint,
        "kind": kind,
        "risk": risk,
        "reason": redact_text(reason, 240),
        "detail": redact_text(detail, 500),
    }
    update_state(mode="approval", risk=risk, last_action=kind, pending=pending)
    log_event("approval_requested", fingerprint=fingerprint, action=kind, risk=risk, reason=reason, detail=detail)

    summary = f"AI approval required [{fingerprint}]"
    body = f"{reason}\n{detail}"
    if policy.get("notifications", {}).get("approval", True):
        notify(summary, redact_text(body, 350), urgency="critical")

    options = [
        f"Approve once [{fingerprint}]",
        "Deny",
        "Pause automation",
        "Emergency stop",
    ]
    prompt_text = f"AI {risk.upper()} · {redact_text(reason, 58)}: "
    try:
        selection = fuzzel_select(options, prompt=prompt_text, width=96)
    except subprocess.TimeoutExpired as exc:
        update_state(mode="ready", pending=None)
        log_event("approval_result", fingerprint=fingerprint, approved=False, result="timeout")
        raise AIUIError("approval timed out", code=52) from exc
    if not selection:
        fallback = terminal_confirmation(f"{summary}\n{body}")
        if fallback == "APPROVE":
            selection = options[0]
        elif fallback == "PAUSE":
            selection = "Pause automation"
        else:
            selection = "Deny"

    if selection == options[0]:
        current = read_state()
        if current.get("mode") == "stopped":
            raise AIUIError("emergency stop was activated while approval was open", code=40)
        if current.get("mode") == "paused":
            raise AIUIError("automation was paused while approval was open", code=41)
        if current.get("session_id") != state.get("session_id"):
            update_state(mode="idle", pending=None)
            raise AIUIError("AIUI session changed while approval was open", code=51)
        update_state(mode="ready", pending=None)
        log_event("approval_result", fingerprint=fingerprint, approved=True)
        return

    if selection == "Pause automation":
        update_state(mode="paused", pending=None, source="approval")
        log_event("approval_result", fingerprint=fingerprint, approved=False, result="paused")
        raise AIUIError("user paused automation", code=41)

    if selection == "Emergency stop":
        emergency_stop(source="approval")
        log_event("approval_result", fingerprint=fingerprint, approved=False, result="stopped")
        raise AIUIError("user emergency-stopped automation", code=40)

    update_state(mode="ready", pending=None)
    log_event("approval_result", fingerprint=fingerprint, approved=False, result="denied")
    raise AIUIError("user denied the action", code=52)


def prepare_action(
    *,
    kind: str,
    requested_risk: str,
    reason: str,
    detail: str,
    allow_sensitive: bool = False,
) -> tuple[str, dict[str, Any] | None]:
    operational_state(require_session=True)
    policy = load_policy()
    window = focused_window()
    sensitive = sensitive_window_reason(window, policy)
    if sensitive and not allow_sensitive:
        log_event("blocked_sensitive_window", action=kind, reason=reason, detail=sensitive)
        if policy.get("notifications", {}).get("blocked", True):
            notify("AI desktop control blocked", sensitive, urgency="critical")
        raise AIUIError("focused window is protected by sensitive-window policy", code=53, details={"why": sensitive})

    inferred, why = infer_content_risk(reason, detail, policy)
    risk = risk_max(requested_risk, inferred)
    request_approval(kind=kind, risk=risk, reason=reason, detail=f"{detail}\nClassifier: {why}")
    operational_state(require_session=True)
    update_state(mode="acting", last_action=kind, risk=risk, last_error="", pending=None)
    return risk, window


def delete_all_screenshots() -> None:
    for path in xdg_runtime_dir().glob("screen-*.png"):
        with contextlib.suppress(OSError):
            path.unlink()


def cleanup_screenshots(policy: dict[str, Any]) -> None:
    cfg = policy.get("screenshot", {})
    max_files = max(1, int(cfg.get("max_files", 8)))
    max_age = max(60, int(cfg.get("max_age_seconds", 900)))
    paths = sorted(xdg_runtime_dir().glob("screen-*.png"), key=lambda p: p.stat().st_mtime, reverse=True)
    cutoff = time.time() - max_age
    for index, path in enumerate(paths):
        try:
            if index >= max_files or path.stat().st_mtime < cutoff:
                path.unlink()
        except OSError:
            pass


def emergency_stop(*, source: str) -> dict[str, Any]:
    state = update_state(
        mode="stopped",
        pending=None,
        source=source,
        last_action="emergency-stop",
        risk="high",
    )
    log_event("emergency_stop", source=source, session_id=state.get("session_id"), task=state.get("task", ""))
    notify("AI desktop automation stopped", f"Source: {source}", urgency="critical")
    return state


def cmd_doctor(_: argparse.Namespace) -> None:
    discover_session_env()
    commands = ["niri", "grim", "wtype", "ydotool", "xdotool", "fuzzel", "notify-send", "footclient", "pkill"]
    found = {name: shutil.which(name) for name in commands}
    niri_ok = False
    niri_error = ""
    try:
        niri_json("version")
        niri_ok = True
    except AIUIError as exc:
        niri_error = str(exc)
    ydotool_socket = os.environ.get("YDOTOOL_SOCKET", "/run/ydotoold/socket")
    result = {
