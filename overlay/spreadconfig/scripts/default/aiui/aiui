def waybar_payload(state: dict[str, Any]) -> dict[str, Any]:
    mode = str(state.get("mode", "error"))
    text_map = {
        "idle": "AI",
        "ready": "AI·",
        "observing": "AI◌",
        "acting": "AI▶",
        "approval": "AI?",
        "paused": "AIⅡ",
        "stopped": "AI■",
        "error": "AI!",
    }
    lines = [
        "AI desktop automation",
        f"State: {mode}",
    ]
    if state.get("session_id"):
        lines.append(f"Session: {state['session_id']}")
    if state.get("task"):
        lines.append(f"Task: {state['task']}")
    if state.get("last_action"):
        lines.append(f"Last action: {state['last_action']}")
    if state.get("risk"):
        lines.append(f"Risk: {state['risk']}")
    pending = state.get("pending")
    if isinstance(pending, dict):
        lines.append(f"Pending: {pending.get('kind', '')} [{pending.get('fingerprint', '')}]")
        lines.append(str(pending.get("reason", "")))
    if state.get("last_error"):
        lines.append(f"Error: {state['last_error']}")
    lines.extend(
        [
            f"Updated: {state.get('updated_at', '')}",
            "Left: controls · Middle: pause/resume · Right: emergency stop",
        ]
    )
    return {
        "text": text_map.get(mode, "AI!"),
        "tooltip": "\n".join(lines),
        "class": mode,
        "alt": mode,
    }


