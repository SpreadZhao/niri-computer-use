def cmd_session_start(args: argparse.Namespace) -> None:
    state = read_state()
    if state.get("mode") == "stopped":
        raise AIUIError("cannot start while emergency-stopped; reset from the Waybar/launcher menu", code=40)
    if state.get("mode") == "paused":
        raise AIUIError("cannot start while paused", code=41)
    if state.get("session_id") and not args.replace:
        raise AIUIError("an AIUI session is already active; end it or pass --replace", code=44)
    session_id = f"{dt.datetime.now().strftime('%Y%m%d-%H%M%S')}-{secrets.token_hex(3)}"
    updated = update_state(
        mode="ready",
        session_id=session_id,
        task=args.task,
        last_action="session-start",
        last_error="",
        risk="low",
        pending=None,
        source=args.source,
    )
    log_event("session_start", session_id=session_id, task=args.task, source=args.source, replaced=bool(state.get("session_id")))
    if load_policy().get("notifications", {}).get("session", True):
        notify("AI desktop automation started", redact_text(args.task, 200))
    emit({"ok": True, "state": updated})


def cmd_session_end(args: argparse.Namespace) -> None:
    state = read_state()
    if state.get("mode") == "stopped":
        # Preserve the stop latch even though the logical task has ended.
        updated = update_state(session_id=None, task="", pending=None, last_action="session-end")
    else:
        updated = update_state(
            mode="idle",
            session_id=None,
            task="",
            pending=None,
            last_action="session-end",
            risk="low",
            source=args.source,
        )
