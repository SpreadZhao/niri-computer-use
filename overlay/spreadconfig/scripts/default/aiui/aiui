def open_audit_log() -> None:
    path = audit_path()
    path.touch(mode=0o600, exist_ok=True)
    command = f"tail -n 200 {shlex.quote(str(path))}; printf '\\nPress Enter to close...'; read -r _"
    env = discover_session_env(os.environ.copy())
    if shutil.which("footclient"):
        argv = ["footclient", "--app-id", "aiui-audit", "--title", "AIUI audit log", "sh", "-lc", command]
    elif shutil.which("foot"):
        argv = ["foot", "--app-id", "aiui-audit", "--title", "AIUI audit log", "sh", "-lc", command]
    else:
        notify("AIUI audit log", str(path))
        return
    subprocess.Popen(argv, env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)


def cmd_menu(args: argparse.Namespace) -> None:
    discover_session_env()
    state = read_state()
    options: list[str] = []
    if state.get("mode") == "stopped":
        options.append("Reset emergency stop")
    elif state.get("mode") == "paused":
        options.append("Resume automation")
    else:
        options.append("Pause automation")
    options.extend(["Emergency stop", "Show current status", "Open audit log", "Cancel"])
    choice = fuzzel_select(options, prompt="AI desktop controls: ", width=74)

    if choice == "Reset emergency stop":
        result = interactive_reset(args.source)
    elif choice == "Resume automation":
        state = update_state(mode="ready" if state.get("session_id") else "idle", source=args.source, last_action="resume")
        log_event("resume", source=args.source)
        result = state
    elif choice == "Pause automation":
        state = update_state(mode="paused", source=args.source, last_action="pause", pending=None)
        log_event("pause", source=args.source)
        result = state
    elif choice == "Emergency stop":
        result = emergency_stop(source=args.source)
    elif choice == "Show current status":
        payload = waybar_payload(read_state())
        notify("AI desktop automation", payload["tooltip"])
        result = read_state()
    elif choice == "Open audit log":
        open_audit_log()
        result = read_state()
    else:
        result = read_state()
    emit({"ok": True, "choice": choice or "cancel", "state": result})


def cmd_observe(args: argparse.Namespace) -> None:
    operational_state(require_session=True)
    policy = load_policy()
    window = focused_window()
    sensitive = sensitive_window_reason(window, policy)
    if sensitive and not args.force_sensitive:
        log_event("observe_blocked", why=sensitive)
        update_state(last_action="observe-blocked", risk="deny")
        if policy.get("notifications", {}).get("blocked", True):
            notify("AI screenshot blocked", sensitive, urgency="critical")
        raise AIUIError("focused window is protected; screenshot was not taken", code=53, details={"why": sensitive})
    if sensitive and args.force_sensitive:
        request_approval(
            kind="observe-sensitive-window",
            risk="high",
            reason="capture a window protected by the sensitive-window policy",
            detail=sensitive,
        )

    update_state(mode="observing", last_action="observe", risk="high" if sensitive else "low", last_error="")
    cleanup_screenshots(policy)
    screenshot: Path | None = None
    try:
        if not args.no_screenshot:
            if not shutil.which("grim"):
                raise AIUIError("grim is not in PATH", code=21)
            stamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
            screenshot = xdg_runtime_dir() / f"screen-{stamp}-{secrets.token_hex(2)}.png"
            argv = ["grim"]
            if args.output:
                argv.extend(["-o", args.output])
            argv.append(str(screenshot))
            cp = run_external(argv, timeout=30)
            if cp.returncode != 0 or not screenshot.is_file() or screenshot.stat().st_size == 0:
                raise AIUIError("grim screenshot failed", code=21, details={"stderr": cp.stderr.strip()})
            with contextlib.suppress(OSError):
                screenshot.chmod(0o600)

        result: dict[str, Any] = {
            "ok": True,
            "screenshot": str(screenshot) if screenshot else None,
            "captured_at": now_iso(),
        }
        for key, query in {
            "focused_window": ("focused-window",),
            "windows": ("windows",),
            "workspaces": ("workspaces",),
            "outputs": ("outputs",),
        }.items():
            try:
                result[key] = unwrap_niri(niri_json(*query))
            except AIUIError as exc:
                result[key] = {"error": str(exc)}
        log_event(
            "observe",
            screenshot=str(screenshot) if screenshot else "",
            focused_app=str((window or {}).get("app_id") or ""),
            focused_title_sha256=hashlib.sha256(str((window or {}).get("title") or "").encode("utf-8")).hexdigest(),
        )
        emit(result)
    finally:
        restore_ready_after_action()


def cmd_type(args: argparse.Namespace) -> None:
    text = sys.stdin.read() if args.stdin else (args.text or "")
    if not text:
        raise AIUIError("text input is empty", code=22)
    policy = load_policy()
    window = focused_window()
    base_risk = args.risk or "medium"
    protected_content = regex_matches(policy.get("deny_content_patterns", []), text)
    if protected_content:
        base_risk = "deny"
    detail = f"type {len(text)} characters into the focused window"
    if protected_content:
        detail += f"; text matches protected-content policy: {protected_content}"
    if len(text) > 500:
        base_risk = risk_max(base_risk, "high")
    if focused_is_terminal(window, policy) and ("\n" in text or "\r" in text):
        command_line = text.strip().splitlines()[0] if text.strip() else ""
        if command_line:
            try:
                command_argv = shlex.split(command_line)
            except ValueError:
                command_argv = [command_line]
            command_risk, why = classify_command(command_argv, policy)
            base_risk = risk_max(base_risk, command_risk)
            detail += f"; focused app appears to be a terminal; command classifier: {why}"
    risk, _ = prepare_action(
        kind="type",
        requested_risk=base_risk,
        reason=args.reason or "type text into the focused application",
        detail=detail,
    )
    try:
        if not shutil.which("wtype"):
            raise AIUIError("wtype is not in PATH", code=22)
        cp = run_external(["wtype", "-d", str(args.delay_ms), "-"], input_text=text, timeout=max(30, len(text) / 20))
        if cp.returncode != 0:
            raise AIUIError("wtype failed", code=22, details={"stderr": cp.stderr.strip()})
        log_event("type", chars=len(text), sha256=hashlib.sha256(text.encode()).hexdigest(), risk=risk, reason=args.reason)
        emit({"ok": True, "chars": len(text), "risk": risk})
    finally:
        restore_ready_after_action()


def parse_hotkey(combo: str) -> tuple[list[str], str]:
    parts = [part.strip().lower() for part in combo.replace(" ", "").split("+") if part.strip()]
    if not parts:
        raise AIUIError("hotkey is empty", code=23)
    aliases = {"super": "logo", "win": "logo", "cmd": "logo", "control": "ctrl"}
    modifiers: list[str] = []
    for raw in parts[:-1]:
        mod = aliases.get(raw, raw)
        if mod not in {"ctrl", "alt", "shift", "logo"}:
            raise AIUIError(f"unsupported modifier: {raw}", code=23)
        if mod not in modifiers:
            modifiers.append(mod)
    key_aliases = {
        "enter": "Return",
        "return": "Return",
        "esc": "Escape",
        "escape": "Escape",
        "space": "space",
        "tab": "Tab",
        "backspace": "BackSpace",
        "delete": "Delete",
        "del": "Delete",
        "up": "Up",
        "down": "Down",
        "left": "Left",
        "right": "Right",
        "home": "Home",
        "end": "End",
        "pageup": "Page_Up",
        "pagedown": "Page_Down",
    }
    key = key_aliases.get(parts[-1], parts[-1])
    return modifiers, key


def cmd_hotkey(args: argparse.Namespace) -> None:
    modifiers, key = parse_hotkey(args.combo)
    normalized = "+".join([*modifiers, key])
    base_risk = args.risk or "medium"
    if normalized.lower() in {"ctrl+return", "alt+f4", "ctrl+w", "shift+delete", "ctrl+shift+return"}:
        base_risk = risk_max(base_risk, "high")
    policy = load_policy()
    window = focused_window()
    if key == "Return" and focused_is_terminal(window, policy):
        base_risk = risk_max(base_risk, "high")
    risk, _ = prepare_action(
        kind="hotkey",
        requested_risk=base_risk,
        reason=args.reason or f"press {normalized}",
        detail=f"press and release hotkey {normalized} in the focused window",
    )
    try:
        if not shutil.which("wtype"):
            raise AIUIError("wtype is not in PATH", code=23)
        argv = ["wtype"]
        for modifier in modifiers:
            argv.extend(["-M", modifier])
        argv.extend(["-P", key, "-p", key])
        for modifier in reversed(modifiers):
            argv.extend(["-m", modifier])
        cp = run_external(argv, timeout=20)
        if cp.returncode != 0:
            raise AIUIError("wtype hotkey failed", code=23, details={"stderr": cp.stderr.strip(), "argv": argv})
        log_event("hotkey", combo=normalized, risk=risk, reason=args.reason)
        emit({"ok": True, "combo": normalized, "risk": risk})
    finally:
        restore_ready_after_action()


