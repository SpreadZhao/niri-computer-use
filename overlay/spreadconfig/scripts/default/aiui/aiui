        emit({"ok": True, "pid": process.pid, "risk": risk, "classifier": why})
    except OSError as exc:
        raise AIUIError("failed to launch GUI command", code=27, details={"error": str(exc), "argv": argv}) from exc
    finally:
        restore_ready_after_action()


def add_source_argument(parser: argparse.ArgumentParser, default: str = "cli") -> None:
    parser.add_argument("--source", default=default)


def add_risk_arguments(parser: argparse.ArgumentParser) -> None:
    parser.add_argument("--reason", default="")
    parser.add_argument("--risk", choices=list(RISK_ORDER))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="aiui", description="Controlled Niri/Wayland computer-use runtime")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    sub = parser.add_subparsers(dest="command", required=True)

    doctor = sub.add_parser("doctor", help="check dependencies and desktop-session integration")
    doctor.set_defaults(func=cmd_doctor)

    session = sub.add_parser("session", help="manage an automation session")
    session_sub = session.add_subparsers(dest="session_command", required=True)
    start = session_sub.add_parser("start")
    start.add_argument("--task", required=True)
    start.add_argument("--replace", action="store_true")
    add_source_argument(start, "agent")
    start.set_defaults(func=cmd_session_start)
    end = session_sub.add_parser("end")
    end.add_argument("--result", default="completed")
    add_source_argument(end, "agent")
    end.set_defaults(func=cmd_session_end)

    status = sub.add_parser("status")
    status.set_defaults(func=cmd_status)

    waybar = sub.add_parser("waybar", help="emit Waybar custom-module JSON")
    waybar.set_defaults(func=cmd_waybar)

    menu = sub.add_parser("menu", help="open the fuzzel control menu")
    add_source_argument(menu, "launcher")
    menu.set_defaults(func=cmd_menu)

    pause = sub.add_parser("pause")
    add_source_argument(pause)
    pause.set_defaults(func=cmd_pause)

    resume = sub.add_parser("resume")
    add_source_argument(resume)
    resume.set_defaults(func=cmd_resume)

    toggle = sub.add_parser("toggle-pause")
    add_source_argument(toggle)
    toggle.set_defaults(func=cmd_toggle_pause)

    stop = sub.add_parser("emergency-stop")
    add_source_argument(stop)
    stop.set_defaults(func=cmd_emergency_stop)

    reset = sub.add_parser("reset-stop", help="interactively re-enable controls after an emergency stop")
    add_source_argument(reset)
    reset.set_defaults(func=cmd_reset)

    observe = sub.add_parser("observe", help="capture the screen and Niri state")
    observe.add_argument("--output", help="capture one Wayland output by name")
    observe.add_argument("--no-screenshot", action="store_true")
    observe.add_argument("--force-sensitive", action="store_true", help="override only after explicit user authorization")
    observe.set_defaults(func=cmd_observe)

    type_cmd = sub.add_parser("type", help="type UTF-8 text with wtype")
    source = type_cmd.add_mutually_exclusive_group(required=True)
    source.add_argument("--text")
    source.add_argument("--stdin", action="store_true")
    type_cmd.add_argument("--delay-ms", type=int, default=12)
    add_risk_arguments(type_cmd)
    type_cmd.set_defaults(func=cmd_type)

    hotkey = sub.add_parser("hotkey", help="press and release a key combination with wtype")
    hotkey.add_argument("combo")
    add_risk_arguments(hotkey)
    hotkey.set_defaults(func=cmd_hotkey)

    click = sub.add_parser("click", help="move and click through ydotool")
    click.add_argument("--x", type=int, required=True)
    click.add_argument("--y", type=int, required=True)
    click.add_argument("--button", choices=["left", "right", "middle"], default="left")
    click.add_argument("--settle-ms", type=int, default=60)
    add_risk_arguments(click)
    click.set_defaults(func=cmd_click)

    x11_click = sub.add_parser("x11-click", help="click a target inside an X11/XWayland window")
    target = x11_click.add_mutually_exclusive_group(required=True)
    target.add_argument("--window-id")
    target.add_argument("--window-name")
    x11_click.add_argument("--x", type=int, required=True, help="window-relative X coordinate")
    x11_click.add_argument("--y", type=int, required=True, help="window-relative Y coordinate")
    x11_click.add_argument("--button", choices=["left", "right", "middle"], default="left")
    add_risk_arguments(x11_click)
    x11_click.set_defaults(func=cmd_x11_click)

    niri_action = sub.add_parser("niri-action")
    niri_action.add_argument("action", choices=["focus-window", "focus-workspace", "toggle-overview", "close-window"])
    niri_action.add_argument("--id", type=int)
    niri_action.add_argument("--index", type=int)
    add_risk_arguments(niri_action)
    niri_action.set_defaults(func=cmd_niri_action)

    run = sub.add_parser("run", help="run an argv-based command without a shell")
    run.add_argument("--cwd")
    run.add_argument("--timeout", type=float, default=60)
    add_risk_arguments(run)
    run.add_argument("argv", nargs=argparse.REMAINDER)
    run.set_defaults(func=cmd_run)

    launch = sub.add_parser("launch", help="start a GUI command and return without waiting for it to exit")
    launch.add_argument("--cwd")
    add_risk_arguments(launch)
    launch.add_argument("argv", nargs=argparse.REMAINDER)
    launch.set_defaults(func=cmd_launch)

    return parser


def main() -> None:
    discover_session_env()
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except AIUIError as exc:
        state = read_state()
        expected_policy_result = exc.code in {40, 41, 42, 43, 50, 51, 52, 53}
        if not expected_policy_result and state.get("mode") not in {"stopped", "paused", "approval"}:
            update_state(
                mode="error" if state.get("session_id") else "idle",
                last_error=str(exc),
                last_action=getattr(args, "command", "unknown"),
                signal_waybar=True,
            )
        log_event("error", command=getattr(args, "command", "unknown"), error=str(exc), code=exc.code, details=exc.details)
        policy: dict[str, Any] = {}
        with contextlib.suppress(AIUIError):
            policy = load_policy()
        if policy.get("notifications", {}).get("error", True) and exc.code not in {40, 41, 42, 43, 52, 53}:
            notify("AI desktop automation error", redact_text(str(exc), 240), urgency="critical")
        emit({"ok": False, "error": str(exc), "details": exc.details}, code=exc.code)
    except subprocess.TimeoutExpired as exc:
        update_state(mode="error", last_error="operation timed out", last_action=getattr(args, "command", "unknown"))
        log_event("timeout", command=getattr(args, "command", "unknown"), timeout=exc.timeout)
        emit({"ok": False, "error": "operation timed out", "timeout": exc.timeout}, code=124)
    except KeyboardInterrupt:
        log_event("interrupted", command=getattr(args, "command", "unknown"))
        emit({"ok": False, "error": "interrupted"}, code=130)
    except Exception as exc:  # Defensive boundary for the local control script.
        update_state(mode="error", last_error=str(exc), last_action=getattr(args, "command", "unknown"))
        log_event("exception", command=getattr(args, "command", "unknown"), error=repr(exc))
        emit({"ok": False, "error": str(exc)}, code=1)


if __name__ == "__main__":
    main()
