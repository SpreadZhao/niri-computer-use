{
  "version": 2,
  "approval_mode": "balanced",
  "require_session": true,
  "waybar_signal": 10,
  "screenshot": {
    "max_files": 8,
    "max_age_seconds": 900,
    "delete_on_session_end": true
  },
  "notifications": {
    "session": true,
    "approval": true,
    "blocked": true,
    "error": true
  },
  "sensitive_app_patterns": [
    "(?i)keepass",
    "(?i)bitwarden",
    "(?i)1password",
    "(?i)org\\.gnome\\.World\\.Secrets",
    "(?i)password",
    "(?i)authenticator"
  ],
  "sensitive_title_patterns": [
    "(?i)password",
    "(?i)passphrase",
    "(?i)private key",
    "(?i)secret",
    "(?i)recovery code",
    "(?i)backup code",
    "(?i)one[- ]time code",
    "(?i)payment",
    "(?i)checkout",
    "密码",
    "口令",
    "密钥",
    "验证码",
    "恢复码",
    "支付",
    "结账"
  ],
  "terminal_app_patterns": [
    "(?i)^foot$",
    "(?i)footclient",
    "(?i)kitty",
    "(?i)wezterm",
    "(?i)alacritty",
    "(?i)terminal"
  ],
  "deny_content_patterns": [
    "(?i)private[ -]?key",
    "(?i)recovery[ -]?code",
    "(?i)backup[ -]?code",
    "(?i)seed phrase",
    "(?i)one[ -]?time password",
    "(?i)credit card",
    "私钥",
    "助记词",
    "恢复码",
    "银行卡号"
  ],
  "high_risk_action_patterns": [
    "(?i)delete",
    "(?i)remove",
    "(?i)erase",
    "(?i)overwrite",
    "(?i)send",
    "(?i)submit",
    "(?i)publish",
    "(?i)post",
    "(?i)purchase",
    "(?i)payment",
    "(?i)install",
    "(?i)uninstall",
    "(?i)system update",
    "(?i)rebuild",
    "(?i)git push",
    "(?i)force",
    "删除",
    "移除",
    "清空",
    "覆盖",
    "发送",
    "提交",
    "发布",
    "购买",
    "支付",
    "安装",
    "卸载",
    "系统更新",
    "重建",
    "推送"
  ],
  "deny_commands": [
    "sudo",
    "su",
    "doas",
    "passwd",
    "mkfs",
    "fdisk",
    "parted",
    "cryptsetup",
    "dd"
  ],
  "high_risk_commands": [
    "rm",
    "mv",
    "cp",
    "install",
    "chmod",
    "chown",
    "systemctl",
    "loginctl",
    "pkill",
    "kill",
    "killall",
    "nixos-rebuild",
    "nix",
    "git",
    "gh",
    "curl",
    "wget",
    "ssh",
    "scp",
    "rsync"
  ],
  "gui_launch_commands": [
    "start_wechat.sh",
    "wechat"
  ],
  "readonly_commands": [
    "ls",
    "pwd",
    "cat",
    "head",
    "tail",
    "wc",
    "printf",
    "echo",
    "rg",
    "grep",
    "fd",
    "stat",
    "file",
    "du",
    "df",
    "jq",
    "realpath",
    "readlink"
  ],
  "blocked_paths": [
    "~/.ssh",
    "~/.gnupg",
    "~/.password-store",
    "~/.config/sops",
    "~/workspaces/spreadconfig/secrets",
    "/etc/shadow",
    "/etc/ssh",
    "/boot"
  ]
}
